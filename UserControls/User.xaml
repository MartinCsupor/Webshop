<Window x:Class="Webshop.UserControls.User"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Webshop.UserControls"
        mc:Ignorable="d"
        Title="User"
    >
    <StackPanel Orientation="Horizontal">
        <DataGrid
        x:Name="datagridUser"
        AutoGenerateColumns="False"
        CanUserAddRows="False"
        CanUserDeleteRows="False"
        IsReadOnly="True"
        SelectionChanged="datagridUser_SelectionChanged"
    >
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header="ID"/>
                <DataGridTextColumn Binding="{Binding Username}" Header="Username"/>
                <DataGridTextColumn Binding="{Binding Email}" Header="Email"/>
                <DataGridTextColumn Binding="{Binding PasswordHash}" Header="Password"/>
                <DataGridTextColumn Binding="{Binding FirstName}" Header="First Name"/>
                <DataGridTextColumn Binding="{Binding LastName}" Header="Last Name"/>
                <DataGridTextColumn Binding="{Binding CreatedAt}" Header="Created at"/>
                <DataGridTextColumn Binding="{Binding IsActive}" Header="Is Active"/>
                <DataGridTextColumn Binding="{Binding Role}" Header="Role"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Window>
